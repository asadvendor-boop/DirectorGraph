# Runtime
ENVIRONMENT=development
APP_MODE=web
STATE_BACKEND=local
APP_VERSION=0.1.0
BUILD_SHA=local
BUILD_TIMESTAMP=local
PROVIDER_MODE=mock
DATABASE_URL=sqlite:////data/directorgraph.db
MEDIA_ROOT=/media
OSS_REPOSITORY_ROOT=/data/oss-repository
FRONTEND_DIST=
PUBLIC_MEDIA_BASE_URL=http://localhost:8000/media
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
SEED_DEMO=true
INLINE_WORKER=true
WORKER_POLL_SECONDS=1.0
MAX_PARALLEL_RENDERS=3
LOG_LEVEL=INFO

# Live cost and judge-run guardrails. These are exposed in readiness now and
# must be enforced before any paid live provider call.
MAX_TOTAL_LIVE_SPEND_USD=40
MAX_PROJECT_SPEND_USD=15
REPAIR_RESERVE_PERCENT=20
MAX_RENDER_ATTEMPTS_PER_SHOT=2
JUDGE_RUN_MAX_DURATION_SECONDS=15
JUDGE_RUN_MAX_SHOTS=3
# Left empty on purpose for local runs: the read-only public-demo pin only applies
# to the hosted deployment. Locally the studio starts empty — create a brief and
# press Run; do not set this unless you have a completed project id to feature.
PUBLIC_DEMO_PROJECT_ID=
JUDGE_CREATE_ACCESS_CODE=
FUNCTION_COMPUTE_TASK_URL=
FUNCTION_COMPUTE_AUTH_HEADER=
FUNCTION_COMPUTE_INVOKE_TIMEOUT_SECONDS=10

# Alibaba Cloud Model Studio / Qwen Cloud (required for PROVIDER_MODE=live)
DASHSCOPE_API_KEY=
DASHSCOPE_NATIVE_BASE_URL=https://ws-q3cz9vsbgt4ypbbg.eu-central-1.maas.aliyuncs.com/api/v1
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
DASHSCOPE_REGION=singapore
QWEN_STORY_MODEL=qwen-plus
QWEN_VISION_MODEL=qwen3-vl-flash
WAN_IMAGE_MODEL=wan2.6-t2i
WAN_VIDEO_MODEL=wan2.6-i2v
WAN_REFERENCE_MODEL=
HAPPYHORSE_VIDEO_MODEL=happyhorse-1.1-t2v
HAPPYHORSE_EDIT_MODEL=happyhorse-1.1-t2v
QWEN_TTS_API_KEY=
QWEN_TTS_BASE_URL=
QWEN_TTS_WORKSPACE_ID=
QWEN_TTS_MODEL=qwen3-tts-flash
QWEN_TTS_VOICE=Cherry
DASHSCOPE_IMAGE_PACE_SECONDS=1.25

# Alibaba Cloud OSS. Strongly recommended for live mode.
OSS_ENDPOINT=
OSS_BUCKET=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_PUBLIC_BASE_URL=
